# Database Configuration (replace with your own values)
SQL_USER=your_sql_user
SQL_PASSWORD=your_sql_password
SQL_SERVER=your_sql_server_host
SQL_PORT=1433
SQL_DATABASE=your_database_name
SQL_ENCRYPT=true
SQL_TRUST_SERVER_CERTIFICATE=true

# Auth (required in production; use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Optional: comma-separated allowed origins (defaults to http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
