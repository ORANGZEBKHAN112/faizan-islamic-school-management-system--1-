# Copy to /var/www/fiss-erp/.env on the VPS (never commit real .env)
NODE_ENV=production
PORT=3000

SQL_SERVER=your_live_sql_host
SQL_PORT=1433
SQL_DATABASE=your_live_database_name
SQL_USER=your_sql_login
SQL_PASSWORD=your_sql_password
SQL_ENCRYPT=true
SQL_TRUST_SERVER_CERTIFICATE=true

# Required in production — generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Optional — only if browser origin differs from API origin
# CORS_ORIGINS=https://erp.yourschool.pk
